{
  "info": {
    "name": "Observerr API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Complete API collection for Observerr — online exam integrity monitoring platform. Includes auth, RBAC, and error case tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Kwame Mensah\",\n  \"email\": \"kwame@university.edu\",\n  \"password\": \"password123\",\n  \"role\": \"LECTURER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Has refresh token\", () => pm.expect(pm.response.json().refreshToken).to.be.a('string'));",
                  "pm.test(\"Token type is Bearer\", () => pm.expect(pm.response.json().tokenType).to.eql('Bearer'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kwame@university.edu\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Has refresh token\", () => pm.expect(pm.response.json().refreshToken).to.be.a('string'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{refreshToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has new access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has email\", () => pm.expect(pm.response.json().email).to.be.a('string'));",
                  "pm.test(\"Has role\", () => pm.expect(pm.response.json().role).to.be.a('string'));",
                  "pm.test(\"No password in response\", () => pm.expect(pm.response.json().password).to.be.undefined);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
