    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Register Duplicate Email (expect 409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"LEC-001\",\n  \"email\": \"kwame@university.edu\",\n  \"password\": \"password123\",\n  \"role\": \"LECTURER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 409 Conflict\", () => pm.response.to.have.status(409));",
                  "pm.test(\"Error is CONFLICT\", () => pm.expect(pm.response.json().error).to.eql('CONFLICT'));",
                  "pm.test(\"Message is correct\", () => pm.expect(pm.response.json().message).to.eql('Email already registered'));",
                  "pm.test(\"Has timestamp\", () => pm.expect(pm.response.json().timestamp).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"LEC-001\",\n  \"password\": \"wrongpassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401 Unauthorized\", () => pm.response.to.have.status(401));",
                  "pm.test(\"Error is UNAUTHORIZED\", () => pm.expect(pm.response.json().error).to.eql('UNAUTHORIZED'));",
                  "pm.test(\"Generic message hides which field was wrong\", () => pm.expect(pm.response.json().message).to.eql('Invalid credentials'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Protected Route Without Token (expect 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401 Unauthorized\", () => pm.response.to.have.status(401));",
                  "pm.test(\"Error is Unauthorized\", () => pm.expect(pm.response.json().error).to.eql('Unauthorized'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register Missing Fields (expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invalid-email\",\n  \"password\": \"short\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 400 Bad Request\", () => pm.response.to.have.status(400));",
                  "pm.test(\"Error is VALIDATION_FAILED\", () => pm.expect(pm.response.json().error).to.eql('VALIDATION_FAILED'));",
                  "pm.test(\"Has field errors map\", () => pm.expect(pm.response.json().errors).to.be.an('object'));",
                  "pm.test(\"Has timestamp\", () => pm.expect(pm.response.json().timestamp).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Non-Existent Email (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"UNKNOWN-999\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 401 Unauthorized\", () => pm.response.to.have.status(401));",
                  "pm.test(\"Same message as wrong password\", () => pm.expect(pm.response.json().message).to.eql('Invalid credentials'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh With Invalid Token (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer this.is.not.a.real.jwt"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "event": [
