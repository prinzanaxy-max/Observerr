{
  "info": {
    "name": "Observerr API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Complete API collection for Observerr — online exam integrity monitoring platform.\n\nSETUP:\n1. Select the 'Observerr' environment (top right)\n2. Run Register or Login first — tokens are saved automatically\n3. All other requests use {{accessToken}} / {{refreshToken}} from the environment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://observerr-production.up.railway.app",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Status is UP\", () => pm.expect(pm.response.json().status).to.eql('UP'));",
                  "pm.test(\"App is Observerr Backend\", () => pm.expect(pm.response.json().app).to.eql('Observerr Backend'));",
                  "pm.test(\"Has timestamp\", () => pm.expect(pm.response.json().timestamp).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Lecturer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"LEC-001\",\n  \"email\": \"kwame@university.edu\",\n  \"password\": \"password123\",\n  \"role\": \"LECTURER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Has refresh token\", () => pm.expect(pm.response.json().refreshToken).to.be.a('string'));",
                  "pm.test(\"Token type is Bearer\", () => pm.expect(pm.response.json().tokenType).to.eql('Bearer'));",
                  "pm.test(\"Role is LECTURER\", () => pm.expect(pm.response.json().role).to.eql('LECTURER'));",
                  "pm.test(\"Has expiresIn\", () => pm.expect(pm.response.json().expiresIn).to.be.a('number'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);",
                  "console.log('Tokens saved to environment');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register (Student)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"STU-001\",\n  \"email\": \"kofi@university.edu\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Role is STUDENT\", () => pm.expect(pm.response.json().role).to.eql('STUDENT'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);",
                  "console.log('Student tokens saved to environment');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"institutionalId\": \"LEC-001\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Has refresh token\", () => pm.expect(pm.response.json().refreshToken).to.be.a('string'));",
                  "pm.test(\"Has institutionalId\", () => pm.expect(pm.response.json().institutionalId).to.be.a('string'));",
                  "pm.test(\"Has role\", () => pm.expect(pm.response.json().role).to.be.a('string'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);",
                  "console.log('Logged in as ' + pm.response.json().role + ' — tokens saved');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{refreshToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has new access token\", () => pm.expect(pm.response.json().accessToken).to.be.a('string'));",
                  "pm.test(\"Has new refresh token\", () => pm.expect(pm.response.json().refreshToken).to.be.a('string'));",
                  "pm.environment.set(\"accessToken\", pm.response.json().accessToken);",
                  "pm.environment.set(\"refreshToken\", pm.response.json().refreshToken);",
                  "console.log('Tokens refreshed and saved');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Has id\", () => pm.expect(pm.response.json().id).to.be.a('number'));",
                  "pm.test(\"Has email\", () => pm.expect(pm.response.json().email).to.be.a('string'));",
                  "pm.test(\"Has institutionalId\", () => pm.expect(pm.response.json().institutionalId).to.be.a('string'));",
                  "pm.test(\"Has role\", () => pm.expect(pm.response.json().role).to.be.a('string'));",
                  "pm.test(\"No password in response\", () => pm.expect(pm.response.json().password).to.be.undefined);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
